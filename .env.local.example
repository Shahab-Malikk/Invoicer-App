# Backend API URL (server-side — used in Server Actions and Server Components)
API_BASE_URL=http://localhost:5000

# Backend API URL (client-side — used in apiClient.ts browser fetch calls)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# External login UI — unauthenticated users are redirected here
# After login, the external app must redirect to: http://localhost:3000/auth/callback?code={code}
NEXT_PUBLIC_AUTH_UI_URL=http://localhost:4005/?app=kycv1

# API key for the external authenticator (if required by your setup)
NEXT_PUBLIC_X_API_KEY=10417b99-db8c-4d26-9913-e160d8f7f04a